# === Database ===
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/autoclip

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === MinIO (S3-compatible) ===
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=autoclip
MINIO_SECURE=false

# === Auth ===
SECRET_KEY=change-this-to-32-char-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=480

# === OpenRouter ===
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxx
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# === Celery ===
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# === App ===
MAX_UPLOAD_SIZE=4294967296
MAX_CONCURRENT_JOBS=3
ENVIRONMENT=development
LOG_LEVEL=INFO

# === Video Processing ===
WHISPER_MODEL=base
SCENE_DETECT_THRESHOLD=27.0
MIN_SCENE_DURATION=3
MAX_SCENES=150
TOP_N_CLIPS=10
OUTPUT_FORMATS=9:16,16:9,1:1
